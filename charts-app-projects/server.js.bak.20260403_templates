    }

    const fromTs = fromDate ? Math.floor(new Date(fromDate + 'T00:00:00Z').getTime() / 1000) : null;
    const toTs   = toDate   ? Math.floor(new Date(toDate   + 'T23:59:59Z').getTime() / 1000) : null;

