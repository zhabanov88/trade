        // Walk-Forward специфичные параметры
        wfWindows    = 5,
        inSamplePct  = 70,
        anchoredStart = false,
        paramRanges  = {
            slValue: [0.5, 1.0, 1.5, 2.0],
            tpValue: [1.5, 2.0, 3.0],
