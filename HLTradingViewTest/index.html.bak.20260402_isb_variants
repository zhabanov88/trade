<script>
    // Переключение вкладок Code Panel
    document.addEventListener('DOMContentLoaded', function() {
        const codeTabs = document.querySelectorAll('.code-tab');
        const codeTabContents = document.querySelectorAll('.code-tab-content');
        
        codeTabs.forEach(tab => {
            tab.addEventListener('click', function() {
                const tabName = this.dataset.tab;
                
                // Убираем active у всех кнопок
                codeTabs.forEach(t => t.classList.remove('active'));
                this.classList.add('active');
                
                // Скрываем все контенты
                codeTabContents.forEach(content => content.classList.remove('active'));
                
                // Показываем нужный контент
                const targetContent = document.getElementById(tabName + '-tab');
                if (targetContent) {
                    targetContent.classList.add('active');
                }
            });
        });


        const currentTheme = localStorage.getItem('tradingview_theme') || 'dark';
        document.querySelector('body').classList = currentTheme + "-theme";

        const saveLoadMenu = document.querySelector('[data-name="save-load-menu"]');

        if (saveLoadMenu) {
            // Добавляем обработчик события клика для добавления истории ранее использованных лэйоутов
            saveLoadMenu.addEventListener('click', () => {
                setTimeout(() => {
                    console.log("Обработано событие клика!");
                }, 300); // Задержка 300 миллисекунд
            });
        }
    });


        // ========== CODE PANEL TOGGLE ==========
        function toggleCodePanel() {
            const panel = document.getElementById('codePanelContainer');
            const strip = document.getElementById('codePanelStrip');
            if (!panel) return;

            const isHidden = panel.classList.toggle('code-panel-hidden');
            if (strip) strip.classList.toggle('code-panel-strip-visible', isHidden);

            localStorage.setItem('codePanelVisible', isHidden ? '0' : '1');

            setTimeout(() => {
                window.dispatchEvent(new Event('resize'));
            }, 310);
        }

        // Восстанавливаем состояние панели при загрузке
        (function restoreCodePanelState() {
            const saved = localStorage.getItem('codePanelVisible');
            if (saved === '0') {
                const panel = document.getElementById('codePanelContainer');
                const strip = document.getElementById('codePanelStrip');
                if (panel) panel.classList.add('code-panel-hidden');
                if (strip) strip.classList.add('code-panel-strip-visible');
            }
        })();
    </script>
