    // Early pre-fetch: auth + layout in parallel (while scripts download)
    window._earlyAuth = fetch('/api/auth/status', {credentials:'include'})
        .then(function(r){return r.ok ? r.json() : {authenticated:false}})
        .catch(function(){return {authenticated:false}});
    try {
        var _s = JSON.parse(localStorage.getItem('tv_session'));
        if (_s && _s.layoutId) {
            window._earlyLayout = fetch('/api/layouts/' + _s.layoutId, {credentials:'include'})
                .then(function(r){return r.ok ? r.json() : null})
                .catch(function(){return null});
        }
