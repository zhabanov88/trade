      TOKEN_PUBLIC_KEY: ${AUTH_TOKEN_PUBLIC_KEY:------BEGIN PUBLIC KEY-----\nMIIBIjANBgkqhkiG9w0BAQEFAAOCAQ8AMIIBCgKCAQEA+HICDZMfimMIiGdd0dPr\n2N3zxHOJqiVXuvUj/aBBS7c8760rJUh4344sP/0Gid558yH/v1MtzZ0R9w09v6gb\nSNrSiNwIUNGPhbnm9Jf+kMezsI/rkcIdoVm3KJ8CFUYy6MRPzW7iJmIVRHBb82v1\nmAYCCQFU6IRtFIa9hQ8wedWwxqXZekSNS+6NB37dmmQB9kz2E3MY+KRLigOh4i3p\nCZ1ti3HVvMa9Rlgk9FmoWExzub5ECChqwm+vn8yFXjYW7kUSClcV2xx4nbQWqjrR\nyyLk6W2BNOuCFVvz0j+5XkpLAt7tljtVZc+572HBEKpF2mAdmAip5NzeDhKqucJ+\nZQIDAQAB\n-----END PUBLIC KEY-----}
      AUTH_ADMIN_PASSWORD: ${AUTH_ADMIN_PASSWORD:-admin}
      AUTH_SIGNUP_DISABLED: ${AUTH_SIGNUP_DISABLED:-false}
      #
      UI_APP_ENDPOINT: ${UI_APP_ENDPOINT:-}
      #
      DISABLE_WILDCARD_COOKIE: 'true'
    depends_on:
      postgres:
        condition: service_healthy
    volumes: []
    networks:
      - shared-network
  #
  ui:
    container_name: datalens-ui
    image: ghcr.io/datalens-tech/datalens-ui:0.3498.0
    environment:
      APP_MODE: full
      APP_ENV: production
      APP_INSTALLATION: opensource
      #
      AUTH_POLICY: disabled
      #
      US_ENDPOINT: http://us:8080
      AUTH_ENDPOINT: http://auth:8080
      BI_API_ENDPOINT: http://control-api:8080
      BI_DATA_ENDPOINT: http://data-api:8080
      META_MANAGER_ENDPOINT: http://meta-manager:8080
      #
      US_MASTER_TOKEN: ${US_MASTER_TOKEN:-us-master-token}
      #
      RELEASE_VERSION: '2.7.0'
      #
      HC: ${HC:-0}
      HC_ENDPOINT: ${HC_ENDPOINT:-}
      HC_PROTOCOL: ${HC_PROTOCOL:-}
      HC_MODULES: ${HC_MODULES:-}
      #
      YANDEX_MAP_ENABLED: ${YANDEX_MAP_ENABLED:-0}
      YANDEX_MAP_TOKEN: ${YANDEX_MAP_TOKEN:-}
      #
      EXPORT_WORKBOOK_ENABLED: ${EXPORT_WORKBOOK_ENABLED:-true}
      #
      AUTH_ENABLED: ${AUTH_ENABLED:-true}
      AUTH_MASTER_TOKEN: ${AUTH_MASTER_TOKEN:-auth-master-token}
      AUTH_TOKEN_PUBLIC_KEY: ${AUTH_TOKEN_PUBLIC_KEY:------BEGIN PUBLIC KEY-----\nMIIBIjANBgkqhkiG9w0BAQEFAAOCAQ8AMIIBCgKCAQEA+HICDZMfimMIiGdd0dPr\n2N3zxHOJqiVXuvUj/aBBS7c8760rJUh4344sP/0Gid558yH/v1MtzZ0R9w09v6gb\nSNrSiNwIUNGPhbnm9Jf+kMezsI/rkcIdoVm3KJ8CFUYy6MRPzW7iJmIVRHBb82v1\nmAYCCQFU6IRtFIa9hQ8wedWwxqXZekSNS+6NB37dmmQB9kz2E3MY+KRLigOh4i3p\nCZ1ti3HVvMa9Rlgk9FmoWExzub5ECChqwm+vn8yFXjYW7kUSClcV2xx4nbQWqjrR\nyyLk6W2BNOuCFVvz0j+5XkpLAt7tljtVZc+572HBEKpF2mAdmAip5NzeDhKqucJ+\nZQIDAQAB\n-----END PUBLIC KEY-----}
      AUTH_SIGNUP_DISABLED: ${AUTH_SIGNUP_DISABLED:-false}
    depends_on:
      - us 
      - clickhouse
    ports:
      - ${UI_PORT:-8080}:8080
    networks:
      - shared-network
#
  grafana:
    image: grafana/grafana:latest
    container_name: grafana
    restart: unless-stopped
    ports:
      - "3000:3000"
    environment:
      - GF_SECURITY_ADMIN_USER=admin
      - GF_SECURITY_ADMIN_PASSWORD=admin123
      - GF_INSTALL_PLUGINS=grafana-clickhouse-datasource,marcusolsson-treemap-panel,ae3e-plotly-panel
      - GF_USERS_ALLOW_SIGN_UP=false
    volumes:
      - grafana-storage:/var/lib/grafana
      - ./grafana/provisioning:/etc/grafana/provisioning
    networks:
      - shared-network
      # ===== TradingView Charts App =====
  charts-app:
    build: ./charts-app
    container_name: charts_app
    depends_on:
      - greenplum-db
      - clickhouse
    networks:
      - shared-network
    ports:
      - "5000:5000"  # Этот порт оставляем открытым только для внутреннего использования
    volumes:
      - ./charts-app:/app
      - /app/node_modules
    restart: unless-stopped
    environment:
      - NODE_ENV=production

  hl-tradingview:
    build: ./HLTradingViewTest
    container_name: hl_tradingview_test
    working_dir: /app
    volumes:
      - ./HLTradingViewTest:/app
    command: sh -c "ls -la /app && npm install && npm start"
    ports:
      - "3001:3000"
      - "8181:8080"
    networks:
      - shared-network
    restart: unless-stopped

  certbot:
    image: certbot/certbot:latest
    container_name: certbot
    volumes:
      - certbot-certs:/etc/letsencrypt
      - certbot-webroot:/var/www/certbot
    networks:
      - shared-network

  nginx-reverse-proxy:
    build: ./Nginx
    container_name: nginx_reverse_proxy
    depends_on:
      - charts-app
      - hl-tradingview
    ports:
      - "5002:5002"
      - "80:80"
      - "5443:5443"
      - "8979:8979"
      - "8124:8124"
      - "6089:6089"
      - "8083:8083"
      - "11435:11435"
      - "11436:11436"
      - "4001:4001"
      - "4002:4002"
    volumes:
      - /etc/ssl:/etc/ssl:ro
      - certbot-certs:/etc/letsencrypt
      - certbot-webroot:/var/www/certbot
      - ./nginx/.htpasswd:/etc/nginx/.htpasswd:ro
    networks:
      - shared-network
    restart: unless-stopped


  # ═══════════════════════════════════════════════════════════════════
  # ██╗      ██╗      ███╗   ███╗    ███████╗███╗   ██╗ ██████╗ ██╗
  # ██║      ██║      ████╗ ████║    ██╔════╝████╗  ██║██╔════╝ ██║
  # ██║      ██║      ██╔████╔██║    █████╗  ██╔██╗ ██║██║  ███╗██║
  # ██║      ██║      ██║╚██╔╝██║    ██╔══╝  ██║╚██╗██║██║   ██║╚═╝
  # ███████╗ ███████╗ ██║ ╚═╝ ██║    ███████╗██║ ╚████║╚██████╔╝██╗
  # ╚══════╝ ╚══════╝ ╚═╝     ╚═╝    ╚══════╝╚═╝  ╚═══╝ ╚═════╝ ╚═╝
  # LOCAL AI — OLLAMA + OPEN-WEBUI + AUTO-PULL MODELS
  # ═══════════════════════════════════════════════════════════════════

  # ─────────────────────────────────────────────────────────────────
  # OLLAMA — движок для запуска локальных LLM
  #
  # Доступ:
  #   API:    http://ollama:11434  (внутри docker сети)
  #   Прямой: http://localhost:11434
  #
  # Для NVIDIA GPU: раскомментировать блок `deploy` ниже.
  # Для CPU-only: оставить как есть (медленнее, но работает).
  # ─────────────────────────────────────────────────────────────────
  ollama:
    image: ollama/ollama:latest
    container_name: ollama
    hostname: ollama
    networks:
      shared-network:
        aliases:
          - ollama
    ports:
      - "11434:11434"     # Ollama API — доступен снаружи
    volumes:
      - ollama-data:/root/.ollama          # модели хранятся здесь (~20-100GB)
    environment:
      - OLLAMA_HOST=0.0.0.0                # слушать на всех интерфейсах
      - OLLAMA_ORIGINS=*                   # CORS для Open WebUI
      - OLLAMA_KEEP_ALIVE=24h              # держать модель в памяти 24 часа
      - OLLAMA_NUM_PARALLEL=2              # параллельные запросы
      - OLLAMA_MAX_LOADED_MODELS=2         # макс. моделей в RAM одновременно
    restart: unless-stopped

    # ── РАСКОММЕНТИРОВАТЬ ДЛЯ NVIDIA GPU ──────────────────────────
    # Требуется: nvidia-container-toolkit установлен на хосте
    # Установка: https://docs.nvidia.com/datacenter/cloud-native/container-toolkit/install-guide.html
    #
    # deploy:
    #   resources:
    #     reservations:
    #       devices:
    #         - driver: nvidia
    #           count: all          # все GPU, или count: 1 для одной
    #           capabilities: [gpu]
    #
    # ── ДЛЯ AMD GPU (ROCm) ─────────────────────────────────────────
    # image: ollama/ollama:rocm
    # devices:
    #   - /dev/kfd
    #   - /dev/dri
    # group_add:
    #   - video
    # ──────────────────────────────────────────────────────────────

  # ─────────────────────────────────────────────────────────────────
  # OLLAMA MODEL PULLER
  # Автоматически скачивает выбранные модели при первом запуске.
  # Запускается один раз, потом завершается (restart: no).
  #
  # 🔧 НАСТРОЙТЕ СПИСОК МОДЕЛЕЙ ПОД ВАШЕ ЖЕЛЕЗО:
  #    Раскомментируйте нужные строки в команде ниже.
  # ─────────────────────────────────────────────────────────────────
  ollama-pull:
    image: ollama/ollama:latest
    container_name: ollama_pull
    depends_on:
      - ollama
    networks:
      - shared-network
    volumes:
      - ollama-data:/root/.ollama
    environment:
      - OLLAMA_HOST=http://ollama:11434
    entrypoint: /bin/bash
    restart: "no"    # запустить один раз и выйти
    command:
      - -c
      - |
        echo "═══════════════════════════════════════════════════"
        echo "  Ollama Model Puller — ожидание запуска сервера..."
        echo "═══════════════════════════════════════════════════"

        # Ждём пока Ollama полностью запустится
        until curl -sf http://ollama:11434/api/tags > /dev/null 2>&1; do
          echo "  Waiting for Ollama API..."
          sleep 3
        done
        echo "  ✅ Ollama API ready!"
        echo ""

        # ──────────────────────────────────────────────────────────
        # СПИСОК МОДЕЛЕЙ ДЛЯ СКАЧИВАНИЯ
        # Раскомментируйте нужные. Каждая модель скачивается один раз
        # и хранится в volume ollama-data.
        #
        # ⚡ БЫСТРЫЙ СТАРТ (минимум RAM):
        # ──────────────────────────────────────────────────────────

        echo "  [1/4] Скачиваем Qwen2.5 Coder 7B (лучший для JS кода, 4.7GB)..."
        ollama pull qwen2.5-coder:7b
        echo "  ✅ qwen2.5-coder:7b готов"
        echo ""

        echo "  [2/4] Скачиваем DeepSeek-R1 8B (рассуждения + код, 4.9GB)..."
        ollama pull deepseek-r1:8b
        echo "  ✅ deepseek-r1:8b готов"
        echo ""

        echo "  [3/4] Скачиваем Llama 3.1 8B (универсальный, 4.7GB)..."
        ollama pull llama3.1:8b
        echo "  ✅ llama3.1:8b готов"
        echo ""

        echo "  [4/4] Скачиваем Phi-4 14B (Microsoft, мощный, 8.9GB)..."
        ollama pull phi4
        echo "  ✅ phi4 готов"
        echo ""

        # ──────────────────────────────────────────────────────────
        # МОЩНЫЕ МОДЕЛИ (раскомментировать при наличии ресурсов)
        # ──────────────────────────────────────────────────────────

        # 16+ GB RAM — рекомендованные для трейдинга:
        echo "  Скачиваем DeepSeek-R1 14B (рассуждения, топ, 9GB)..."
        ollama pull deepseek-r1:14b

        # echo "  Скачиваем Qwen2.5-Coder 14B (лучший для кода, 9GB)..."
        # ollama pull qwen2.5-coder:14b

        # 24+ GB RAM — продвинутый уровень:
        echo "  Скачиваем DeepSeek-R1 32B (reasoning, 20GB)..."
        ollama pull deepseek-r1:32b

        echo "  Скачиваем Qwen2.5-Coder 32B (топ кодер, 20GB)..."
        ollama pull qwen2.5-coder:32b

        # 48+ GB RAM или GPU — максимальное качество:
        echo "  Скачиваем Llama 3.3 70B (флагман Meta, 43GB)..."
        ollama pull llama3.3

        echo "  Скачиваем DeepSeek-R1 70B (лучшие рассуждения, 43GB)..."
        ollama pull deepseek-r1:70b

        echo "  Скачиваем Qwen2.5 72B (лучший универсал, 47GB)..."
        ollama pull qwen2.5:72b

        # ──────────────────────────────────────────────────────────

        echo "═══════════════════════════════════════════════════"
        echo "  ✅ Все модели готовы!"
        echo ""
        echo "  Доступные модели:"
        curl -s http://ollama:11434/api/tags | grep -o '"name":"[^"]*"' | sed 's/"name":"//;s/"//' | sort | while read m; do
          echo "    • $m"
        done
        echo ""
        echo "  Настройте в ⚙️ LLM → Ollama → http://ollama:11434"
        echo "═══════════════════════════════════════════════════"

  # ─────────────────────────────────────────────────────────────────
  # OPEN WEBUI — красивый веб-интерфейс для Ollama
  #
  # Доступ: http://localhost:6089  (или через nginx)
  # При первом входе создайте аккаунт администратора.
  #
  # Возможности:
  #   • Чат с любой моделью через браузер
  #   • Загрузка документов (RAG)
  #   • Создание кастомных ассистентов
  #   • История разговоров
  #   • Управление моделями через UI
  # ─────────────────────────────────────────────────────────────────
  open-webui:
    image: ghcr.io/open-webui/open-webui:main
    container_name: open_webui
    hostname: open-webui
    depends_on:
      - ollama
    networks:
      - shared-network
    volumes:
      - open-webui-data:/app/backend/data
    environment:
      - OLLAMA_BASE_URL=http://ollama:11434    # Ollama внутри docker сети
      - WEBUI_SECRET_KEY=${WEBUI_SECRET_KEY:-change_this_secret_key_in_env}
      - WEBUI_NAME=Trading AI Assistant
      - WEBUI_URL=http://localhost:6089
      - DEFAULT_MODELS=qwen2.5-coder:7b       # модель по умолчанию при входе
      - ENABLE_SIGNUP=true                     # разрешить регистрацию
      - ENABLE_LOGIN_FORM=true
      # RAG настройки
      - RAG_EMBEDDING_ENGINE=ollama
      - RAG_EMBEDDING_MODEL=nomic-embed-text   # модель для embeddings
      # Производительность
      - AIOHTTP_CLIENT_TIMEOUT=300
    restart: unless-stopped

  # ─────────────────────────────────────────────────────────────────
  # LITELLM — прокси-сервер: единый OpenAI-совместимый API
  # для ВСЕХ провайдеров (Ollama + облачные ключи)
  #
  # Доступ:  http://localhost:4000
  # Swagger: http://localhost:4000/docs
  #
  # Позволяет переключать модели без изменения кода приложения:
  #   POST http://litellm:4000/v1/chat/completions
  #   { "model": "ollama/qwen2.5-coder:7b", ... }
  #   { "model": "gpt-4o", ... }            ← если задан OPENAI_API_KEY
  #   { "model": "claude-opus-4-6", ... }   ← если задан ANTHROPIC_API_KEY
  # ─────────────────────────────────────────────────────────────────
  litellm:
    image: ghcr.io/berriai/litellm:main-latest
    container_name: litellm
    hostname: litellm
    depends_on:
      - ollama
    networks:
      - shared-network
    ports:
      - "4000:4000"     # LiteLLM API → http://localhost:4000
    volumes:
      - ./litellm-config.yaml:/app/config.yaml:ro
    environment:
      # Облачные ключи (опционально — добавьте в .env)
      - ANTHROPIC_API_KEY=${ANTHROPIC_API_KEY:-}
      - OPENAI_API_KEY=${OPENAI_API_KEY:-}
      - DEEPSEEK_API_KEY=${DEEPSEEK_API_KEY:-}
      - GROQ_API_KEY=${GROQ_API_KEY:-}
      - GEMINI_API_KEY=${GEMINI_API_KEY:-}
      # LiteLLM мастер-ключ для API
      - LITELLM_MASTER_KEY=${LITELLM_MASTER_KEY:-sk-trading-platform-master}
    command: ["--config", "/app/config.yaml", "--port", "4000", "--detailed_debug"]
    restart: unless-stopped

volumes:
  clickhouse-data:
  cloudbeaver-data:
  db-postgres:
  grafana-storage:
  certbot-certs:
  certbot-webroot:
  ollama-data:        # ← хранит скачанные модели (может быть 20-100GB)
  open-webui-data:    # ← данные Open WebUI (история, настройки)

networks:
  default:
    enable_ipv6: true
  shared-network:
    driver: bridge